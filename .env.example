# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Slack notifications
SLACK_WEBHOOK_URL=your_slack_webhook_url_here

# Admin auth (simple password for V1)
ADMIN_PASSWORD=your_admin_password_here

# Signs the admin session cookie (falls back to ADMIN_PASSWORD if unset)
SESSION_SECRET=

# Granola meeting sync (api/granola/*)
GRANOLA_API_KEY=

# Meeting-brief generation from a raw transcript (api/rooms + api/rooms/from-granola).
# Groq only — free, OpenAI-compatible. Without it the raw transcript is kept
# verbatim so room creation never fails. GROQ_MODEL overrides the default model
# (llama-3.3-70b-versatile).
GROQ_API_KEY=
GROQ_MODEL=

# Anthropic — optional from-granola brief rewrite/scrub (api/rooms/from-granola);
# falls back to a deterministic scrub when unset. ANTHROPIC_MODEL overrides it.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
# Alternative to ANTHROPIC_API_KEY for the ideation engine: a Claude subscription
# OAuth token (mint with `claude setup-token`). If set, the ideation engine uses
# it (Bearer + oauth beta header) instead of ANTHROPIC_API_KEY. Short-lived and
# not auto-refreshed — re-mint when it expires. Does not affect from-granola.
ANTHROPIC_AUTH_TOKEN=

# Ideation engine (api/ideation/*) — all optional
# LLM provider for ideation runs:
#  - If OPENROUTER_API_KEY is set → OpenRouter (OpenAI-compatible). ENGINE_MODEL
#    must be an OpenRouter slug (default: anthropic/claude-haiku-4.5). No prompt
#    caching on this path.
#  - Otherwise → Anthropic API (ANTHROPIC_AUTH_TOKEN or ANTHROPIC_API_KEY) with a
#    bare model id (default: claude-haiku-4-5).
OPENROUTER_API_KEY=
# Model override — must match the active provider (see above).
ENGINE_MODEL=
# Where the weekly digest posts (falls back to SLACK_WEBHOOK_URL, then stdout)
DIGEST_WEBHOOK_URL=
