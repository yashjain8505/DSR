# Supabase
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# Slack notifications
SLACK_WEBHOOK_URL=your_slack_webhook_url_here

# Admin auth (simple password for V1)
ADMIN_PASSWORD=your_admin_password_here

# Signs the admin session cookie (falls back to ADMIN_PASSWORD if unset)
SESSION_SECRET=

# Granola meeting sync (api/granola/*)
GRANOLA_API_KEY=

# Anthropic — room generation from Granola briefs (api/rooms/from-granola)
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=
